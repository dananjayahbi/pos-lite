// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
  STOCK_CLERK
}

enum TenantStatus {
  ACTIVE
  GRACE_PERIOD
  SUSPENDED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum InvoiceStatus {
  PAID
  UNPAID
  OVERDUE
}

enum GenderType {
  MEN
  WOMEN
  UNISEX
  KIDS
  TODDLERS
}

enum TaxRule {
  STANDARD_VAT
  SSCL
  EXEMPT
}

enum StockMovementReason {
  FOUND
  DAMAGED
  STOLEN
  DATA_ERROR
  RETURNED_TO_SUPPLIER
  INITIAL_STOCK
  SALE_RETURN
  PURCHASE_RECEIVED
  STOCK_TAKE_ADJUSTMENT
  SALE
  VOID_REVERSAL
}

enum StockTakeStatus {
  IN_PROGRESS
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum NotificationType {
  LOW_STOCK_ALERT
  STOCK_TAKE_SUBMITTED
  STOCK_TAKE_APPROVED
  STOCK_TAKE_REJECTED
  SYSTEM_ALERT
}

enum PaymentMethod {
  CASH
  CARD
  SPLIT
}

enum PaymentLegMethod {
  CASH
  CARD
}

enum SaleStatus {
  OPEN
  COMPLETED
  VOIDED
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum ReturnRefundMethod {
  CASH
  CARD_REVERSAL
  STORE_CREDIT
  EXCHANGE
}

enum ReturnStatus {
  COMPLETED
}

// ── Auth Models ──────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  tenantId       String?
  tenant         Tenant?   @relation(fields: [tenantId], references: [id])
  email          String    @unique
  passwordHash   String
  pin            String?
  role           UserRole
  permissions    Json      @default("[]")
  isActive       Boolean   @default(true)
  sessionVersion Int       @default(1)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  sessions       Session[]
  stockMovements StockMovement[]
  initiatedStockTakes StockTakeSession[] @relation("StockTakeInitiator")
  approvedStockTakes  StockTakeSession[] @relation("StockTakeApprover")
  notifications        NotificationRecord[]
  salesAsCashier       Sale[]             @relation("SaleCashier")
  salesAsAuthManager   Sale[]             @relation("SaleAuthorizingManager")
  salesAsVoidActor     Sale[]             @relation("SaleVoidActor")
  shiftsAsCashier      Shift[]            @relation("ShiftCashier")
  shiftClosures        ShiftClosure[]     @relation("ShiftCloser")
  returnsAsInitiator   Return[]           @relation("ReturnInitiator")
  returnsAsAuthorizer  Return[]           @relation("ReturnAuthorizer")

  @@index([email])
  @@index([tenantId])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Audit ────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?
  actorId    String?
  actorRole  String
  entityType String
  entityId   String
  action     String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, actorId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── SaaS Models ──────────────────────────────────────────────────────────────

model Plan {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String
  priceMonthly  Decimal  @db.Decimal(12, 2)
  features      Json
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)

  subscriptions Subscription[]

  @@map("plans")
}

model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  logoUrl      String?
  status       TenantStatus @default(ACTIVE)
  graceEndsAt  DateTime?
  customDomain String?
  settings     Json
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  users         User[]
  subscriptions Subscription[]
  invoices      Invoice[]
  categories    Category[]
  brands        Brand[]
  products      Product[]
  productVariants ProductVariant[]
  stockMovements StockMovement[]
  stockTakeSessions StockTakeSession[]
  notifications      NotificationRecord[]
  sales              Sale[]
  shifts             Shift[]
  storeCredits       StoreCredit[]

  @@map("tenants")
}

model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  planId             String
  plan               Plan               @relation(fields: [planId], references: [id])
  status             SubscriptionStatus
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  payhereSubId       String?
  nextBillingDate    DateTime
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  invoices Invoice[]

  @@index([tenantId])
  @@index([planId])
  @@map("subscriptions")
}

model Invoice {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  invoiceNumber  String        @unique
  amount         Decimal       @db.Decimal(12, 2)
  status         InvoiceStatus
  billingDate    DateTime
  paidAt         DateTime?
  pdfUrl         String?
  createdAt      DateTime      @default(now())

  @@index([tenantId])
  @@index([subscriptionId])
  @@map("invoices")
}

// ── Catalog Models ───────────────────────────────────────────────────────────

model Category {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  products    Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("categories")
}

model Brand {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  logoUrl     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  products    Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("brands")
}

model Product {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])
  brandId     String?
  brand       Brand?     @relation(fields: [brandId], references: [id])
  gender      GenderType
  tags        String[]   @default([])
  taxRule     TaxRule    @default(STANDARD_VAT)
  isArchived  Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  variants    ProductVariant[]

  @@index([tenantId])
  @@index([tenantId, categoryId])
  @@index([tenantId, isArchived, deletedAt])
  @@map("products")
}

model ProductVariant {
  id                String    @id @default(cuid())
  productId         String
  product           Product   @relation(fields: [productId], references: [id])
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id])
  sku               String
  barcode           String?
  size              String?
  colour            String?
  costPrice         Decimal   @db.Decimal(12, 2)
  retailPrice       Decimal   @db.Decimal(12, 2)
  wholesalePrice    Decimal?  @db.Decimal(12, 2)
  stockQuantity     Int       @default(0)
  lowStockThreshold Int       @default(5)
  imageUrls         String[]  @default([])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  stockMovements    StockMovement[]
  stockTakeItems    StockTakeItem[]
  saleLines         SaleLine[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId])
  @@index([productId, tenantId])
  @@index([barcode, tenantId])
  @@map("product_variants")
}

model StockMovement {
  id                  String              @id @default(cuid())
  tenantId            String
  tenant              Tenant              @relation(fields: [tenantId], references: [id])
  variantId           String
  variant             ProductVariant      @relation(fields: [variantId], references: [id])
  reason              StockMovementReason
  quantityDelta       Int
  quantityBefore      Int
  quantityAfter       Int
  actorId             String
  actor               User                @relation(fields: [actorId], references: [id])
  note                String?
  saleId              String?
  purchaseOrderId     String?
  stockTakeSessionId  String?
  createdAt           DateTime            @default(now())

  @@index([variantId, createdAt])
  @@index([tenantId, createdAt])
  @@index([actorId])
  @@map("stock_movements")
}

model StockTakeSession {
  id            String          @id @default(cuid())
  tenantId      String
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  categoryId    String?
  status        StockTakeStatus @default(IN_PROGRESS)
  initiatedById String
  initiatedBy   User            @relation("StockTakeInitiator", fields: [initiatedById], references: [id])
  approvedById  String?
  approvedBy    User?           @relation("StockTakeApprover", fields: [approvedById], references: [id])
  startedAt     DateTime        @default(now())
  completedAt   DateTime?
  approvedAt    DateTime?
  notes         String?

  items         StockTakeItem[]

  @@index([tenantId, status])
  @@map("stock_take_sessions")
}

model StockTakeItem {
  id              String           @id @default(cuid())
  sessionId       String
  session         StockTakeSession @relation(fields: [sessionId], references: [id])
  variantId       String
  variant         ProductVariant   @relation(fields: [variantId], references: [id])
  systemQuantity  Int
  countedQuantity Int?
  discrepancy     Int?
  isRecounted     Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([sessionId, variantId])
  @@index([sessionId])
  @@map("stock_take_items")
}

// ── Notifications ────────────────────────────────────────────────────────────

model NotificationRecord {
  id                String           @id @default(cuid())
  tenantId          String
  tenant            Tenant           @relation(fields: [tenantId], references: [id])
  recipientId       String
  recipient         User             @relation(fields: [recipientId], references: [id])
  type              NotificationType
  title             String
  body              String
  relatedEntityType String?
  relatedEntityId   String?
  isRead            Boolean          @default(false)
  createdAt         DateTime         @default(now())

  @@index([tenantId, recipientId, isRead])
  @@index([tenantId, recipientId, createdAt])
  @@map("notification_records")
}

// ── POS Models ───────────────────────────────────────────────────────────────

model Sale {
  id                    String         @id @default(cuid())
  tenantId              String
  tenant                Tenant         @relation(fields: [tenantId], references: [id])
  shiftId               String
  shift                 Shift          @relation(fields: [shiftId], references: [id])
  cashierId             String
  cashier               User           @relation("SaleCashier", fields: [cashierId], references: [id])
  subtotal              Decimal        @db.Decimal(12, 2)
  discountAmount        Decimal        @default(0) @db.Decimal(12, 2)
  taxAmount             Decimal        @db.Decimal(12, 2)
  totalAmount           Decimal        @db.Decimal(12, 2)
  changeGiven           Decimal?       @db.Decimal(12, 2)
  authorizingManagerId  String?
  authorizingManager    User?          @relation("SaleAuthorizingManager", fields: [authorizingManagerId], references: [id])
  paymentMethod         PaymentMethod?
  status                SaleStatus     @default(OPEN)
  voidedById            String?
  voidedBy              User?          @relation("SaleVoidActor", fields: [voidedById], references: [id])
  voidedAt              DateTime?
  whatsappReceiptSentAt DateTime?
  completedAt           DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  lines                 SaleLine[]
  payments              Payment[]    @relation("SalePayments")
  linkedReturnId        String?
  linkedReturn          Return?        @relation("ExchangeLinkedSale", fields: [linkedReturnId], references: [id], onDelete: SetNull)
  returns               Return[]       @relation("ReturnOriginalSale")

  @@index([tenantId, status, createdAt])
  @@index([shiftId])
  @@index([cashierId])
  @@map("sales")
}

model SaleLine {
  id                         String         @id @default(cuid())
  saleId                     String
  sale                       Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variantId                  String
  variant                    ProductVariant @relation(fields: [variantId], references: [id])
  productNameSnapshot        String
  variantDescriptionSnapshot String
  sku                        String
  unitPrice                  Decimal        @db.Decimal(12, 2)
  quantity                   Int
  discountPercent            Decimal        @default(0) @db.Decimal(12, 2)
  discountAmount             Decimal        @default(0) @db.Decimal(12, 2)
  lineTotalBeforeDiscount    Decimal        @db.Decimal(12, 2)
  lineTotalAfterDiscount     Decimal        @db.Decimal(12, 2)
  createdAt                  DateTime       @default(now())

  returnLines           ReturnLine[]

  @@index([saleId])
  @@index([variantId])
  @@map("sale_lines")
}

// Sum of Payment.amount must equal Sale.totalAmount — enforced in sale.service createSale transaction
model Payment {
  id                  String           @id @default(cuid())
  saleId              String
  sale                Sale             @relation("SalePayments", fields: [saleId], references: [id], onDelete: Cascade)
  method              PaymentLegMethod
  amount              Decimal          @db.Decimal(12, 2)
  cardReferenceNumber String?
  createdAt           DateTime         @default(now())

  @@index([saleId])
  @@map("payments")
}

model Shift {
  id           String      @id @default(cuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  cashierId    String
  cashier      User        @relation("ShiftCashier", fields: [cashierId], references: [id])
  status       ShiftStatus @default(OPEN)
  openedAt     DateTime    @default(now())
  closedAt     DateTime?
  openingFloat Decimal     @db.Decimal(12, 2)
  notes        String?

  sales        Sale[]
  closure      ShiftClosure?

  @@index([tenantId, status])
  @@index([cashierId, status])
  @@index([tenantId, openedAt])
  @@map("shifts")
}

model ShiftClosure {
  id                 String   @id @default(cuid())
  shiftId            String   @unique
  shift              Shift    @relation(fields: [shiftId], references: [id])
  closingCashCount   Decimal  @db.Decimal(12, 2)
  expectedCash       Decimal  @db.Decimal(12, 2)
  cashDifference     Decimal  @db.Decimal(12, 2)
  totalSalesCount    Int
  totalSalesAmount   Decimal  @db.Decimal(12, 2)
  totalReturnsCount  Int      @default(0)
  totalReturnsAmount Decimal  @default(0) @db.Decimal(12, 2)
  totalCashAmount    Decimal  @db.Decimal(12, 2)
  totalCardAmount    Decimal  @db.Decimal(12, 2)
  closedById         String
  closedBy           User     @relation("ShiftCloser", fields: [closedById], references: [id])
  closedAt           DateTime @default(now())

  @@map("shift_closures")
}

// ── Returns & Exchanges ──────────────────────────────────────────────────────

model Return {
  id              String             @id @default(cuid())
  tenantId        String
  originalSaleId  String
  originalSale    Sale               @relation("ReturnOriginalSale", fields: [originalSaleId], references: [id], onDelete: Restrict)
  initiatedById   String
  initiatedBy     User               @relation("ReturnInitiator", fields: [initiatedById], references: [id])
  authorizedById  String
  authorizedBy    User               @relation("ReturnAuthorizer", fields: [authorizedById], references: [id])
  refundMethod    ReturnRefundMethod
  refundAmount    Decimal            @db.Decimal(12, 2)
  restockItems    Boolean            @default(true)
  reason          String
  status          ReturnStatus       @default(COMPLETED)
  createdAt       DateTime           @default(now())

  lines           ReturnLine[]
  linkedSales     Sale[]             @relation("ExchangeLinkedSale")

  @@index([tenantId, createdAt])
  @@index([originalSaleId])
  @@map("returns")
}

model ReturnLine {
  id                         String     @id @default(cuid())
  returnId                   String
  return                     Return     @relation(fields: [returnId], references: [id], onDelete: Cascade)
  originalSaleLineId         String
  originalSaleLine           SaleLine   @relation(fields: [originalSaleLineId], references: [id])
  variantId                  String
  productNameSnapshot        String
  variantDescriptionSnapshot String
  quantity                   Int
  unitPrice                  Decimal    @db.Decimal(12, 2)
  lineRefundAmount           Decimal    @db.Decimal(12, 2)
  isRestocked                Boolean    @default(false)
  createdAt                  DateTime   @default(now())

  @@index([returnId])
  @@map("return_lines")
}

model StoreCredit {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  customerId String?
  amount     Decimal   @db.Decimal(12, 2)
  usedAmount Decimal   @default(0) @db.Decimal(12, 2)
  note       String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@map("store_credits")
}
